{
  "name": "riskoff-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Riskoff MCP server for personalized prediction-market discovery, hedging, and paper trading.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:http": "MCP_TRANSPORT=http tsx src/index.ts",
    "local": "bash scripts/start-local.sh",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "test": "node --import tsx --test test/**/*.test.ts",
    "check": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
