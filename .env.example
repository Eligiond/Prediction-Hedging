# stdio (default) or http
MCP_TRANSPORT=stdio
PORT=3000
HOST=127.0.0.1

# Comma-separated browser origins for HTTP mode. Empty means no cross-origin access.
ALLOWED_ORIGINS=http://localhost:3000
# Recommended whenever HTTP is exposed beyond localhost.
MCP_API_TOKEN=

# Optional: enables embedding-based ranking. Local concept-aware ranking is the fallback.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional MemPalace installation. Defaults to ~/.mempalace/palace.
MEMPALACE_PATH=
MEMPALACE_PYTHON=./.venv/bin/python
DATA_DIR=./data
